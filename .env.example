APP_NAME="SaaS Starter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Tenancy - central domain (subdomains resolve against this)
CENTRAL_DOMAIN=localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saas_starter
DB_USERNAME=root
DB_PASSWORD=

# Each tenant gets their own DB automatically
TENANCY_DB_PREFIX=tenant_

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@saas-starter.test"
MAIL_FROM_NAME="${APP_NAME}"

# Stripe — create keys at https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET=sk_test_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Stripe Price IDs — create plans at https://dashboard.stripe.com/products
STRIPE_PLAN_STARTER=price_STARTER_PLAN_ID
STRIPE_PLAN_PRO=price_PRO_PLAN_ID
STRIPE_PLAN_ENTERPRISE=price_ENTERPRISE_PLAN_ID

# Super Admin API key — use a strong random value in production
SUPER_ADMIN_KEY=super-admin-dev-key-change-in-production
